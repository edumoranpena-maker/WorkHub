            Your workspace
          </span>
        </div>
        <h1 style={{ margin: 0, color: C.text, fontFamily: font, fontSize: 26, fontWeight: 800, letterSpacing: "-0.03em", lineHeight: 1.2 }}>
          Good morning,{" "}
          <span style={{ background: `linear-gradient(90deg, ${C.accentLight}, #c4b5fd)`, WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent" }}>
            team.
          </span>
        </h1>
        <p style={{ margin: "6px 0 0", color: C.textMuted, fontFamily: font, fontSize: 14 }}>
          4 new updates since your last visit
        </p>
      </motion.div>

      {/* Stats */}
      <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} transition={{ delay: 0.15, duration: 0.35 }}
        style={{ display: "flex", gap: 10, padding: "16px 20px", overflowX: "auto", scrollbarWidth: "none" }}>
        {[
          { icon: TrendingUp, label: "Active",   value: "24", color: C.green       },
          { icon: Clock,      label: "Pending",  value: "7",  color: C.amber       },
          { icon: Bell,       label: "Mentions", value: "3",  color: C.accentLight },
        ].map((stat) => (
          <div key={stat.label} style={{
            flex: "0 0 auto", display: "flex", alignItems: "center", gap: 8,
            background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: "9px 14px",
          }}>
            <stat.icon size={14} color={stat.color} strokeWidth={2} />
            <span style={{ color: C.textMuted, fontFamily: font, fontSize: 12, fontWeight: 500 }}>{stat.label}</span>
            <span style={{ color: stat.color, fontFamily: font, fontSize: 13, fontWeight: 700 }}>{stat.value}</span>
          </div>
        ))}
      </motion.div>

      {/* Section divider */}
      <div style={{ padding: "0 20px 8px" }}>
        <p style={{ margin: 0, fontFamily: font, fontSize: 11, fontWeight: 700, color: C.textMuted, textTransform: "uppercase", letterSpacing: "0.08em" }}>
          Latest from each section
        </p>
      </div>

      {/* Preview posts */}
      <div style={{ display: "flex", flexDirection: "column", gap: 10, padding: "4px 20px 32px" }}>
        {SECTIONS.map((s, i) => (
          <motion.div key={s.id} initial={{ opacity: 0, y: 16 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: 0.1 + i * 0.08 }}>
            <HomePreviewCard section={s} onClick={() => onNavigate(s.id)} />
          </motion.div>
        ))}
      </div>
    </div>
  );
}

// ─── GenericSectionScreen ─────────────────────────────────────────────────────
function GenericSectionScreen({ section, onBack, onNavigate, isHost }) {
  const isDesktop = useIsDesktop();
  const posts = [
    { id: 1, title: "Week 28 — Team Recap",       meta: "Today",       pinned: true,  tag: "Weekly"    },
    { id: 2, title: "Backend API milestone hit",   meta: "2 days ago",  pinned: false, tag: "Milestone" },
    { id: 3, title: "Design review — July",        meta: "1 week ago",  pinned: false, tag: "Design"    },
  ];

  const FeedContent = () => (
    <div style={{ display: "flex", flexDirection: "column", gap: 8, padding: isDesktop ? "20px 28px 48px" : "16px 18px 32px", maxWidth: isDesktop ? 760 : "none", margin: isDesktop ? "0 auto" : 0 }}>
      {posts.map((p, i) => (
        <motion.div key={p.id} initial={{ opacity: 0, x: 16 }} animate={{ opacity: 1, x: 0 }}
          transition={{ delay: 0.06 + i * 0.07 }}
          style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 16, padding: "16px 18px", display: "flex", alignItems: "center", gap: 14, cursor: "pointer" }}>
          <div style={{ width: 3, height: 36, borderRadius: 99, background: p.pinned ? section.accentColor : C.border, flexShrink: 0 }} />
          <div style={{ flex: 1 }}>
            <div style={{ display: "flex", alignItems: "center", gap: 7, marginBottom: 3 }}>
              {p.pinned && <Pin size={11} color={section.accentColor} strokeWidth={2.5} />}
              <span style={{ color: C.text, fontFamily: font, fontSize: 14, fontWeight: 600 }}>{p.title}</span>
            </div>
            <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
              <span style={{ color: C.textMuted, fontFamily: font, fontSize: 12 }}>{p.meta}</span>
              <span style={{ fontSize: 11, fontWeight: 600, color: section.accentColor, background: `${section.accentColor}18`, borderRadius: 6, padding: "2px 7px", fontFamily: font }}>{p.tag}</span>
            </div>
          </div>
        </motion.div>
      ))}
    </div>
  );

  if (isDesktop) {
    return (
      <div style={{ display: "flex", height: "100%", overflow: "hidden", background: C.bg }}>
        <Sidebar activeId={section.id} onNavigate={onNavigate} onBack={onBack} />
        <div style={{ flex: 1, overflowY: "auto", overflowX: "hidden" }}>
          {/* Top bar */}
          <div style={{
            position: "sticky", top: 0, zIndex: 30,
            background: `${C.surface}f2`, backdropFilter: "blur(24px)",
            borderBottom: `1px solid ${C.border}`, padding: "14px 28px",
            display: "flex", alignItems: "center", justifyContent: "space-between",
          }}>
            <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
              <div style={{
                width: 36, height: 36, borderRadius: 10,
                background: `${section.accentColor}20`, border: `1px solid ${section.accentColor}30`,
                display: "flex", alignItems: "center", justifyContent: "center",
              }}>
                <section.icon size={18} color={section.accentColor} strokeWidth={1.8} />
              </div>
              <div>
                <h2 style={{ margin: 0, fontFamily: font, fontSize: 18, fontWeight: 800, color: C.text }}>{section.label}</h2>
                <p style={{ margin: 0, fontFamily: font, fontSize: 12, color: C.textMuted }}>{section.subtitle}</p>
              </div>
            </div>
            <span style={{ fontFamily: font, fontSize: 10, fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.08em", color: isHost ? C.accentLight : C.textMuted, background: isHost ? `${C.accent}18` : C.border + "80", border: `1px solid ${isHost ? C.accent + "30" : C.border}`, borderRadius: 6, padding: "3px 7px" }}>
              {isHost ? "Host" : "Member"}
            </span>
          </div>
          <FeedContent />
        </div>
      </div>
    );
  }

  // Mobile
  return (
    <div style={{ height: "100%", overflowY: "auto" }}>
      <MobileTopBar title={section.label} onBack={onBack} accent={section.accentColor} />
      <motion.div initial={{ opacity: 0, y: 12 }} animate={{ opacity: 1, y: 0 }}
        style={{ padding: "20px 18px 16px", borderBottom: `1px solid ${C.border}`, position: "relative", overflow: "hidden" }}>
        <div style={{ position: "absolute", top: -40, right: -40, width: 160, height: 160, borderRadius: "50%", background: section.glowColor, filter: "blur(50px)", pointerEvents: "none" }} />
        <div style={{ display: "flex", alignItems: "center", gap: 14, position: "relative" }}>
          <div style={{
            width: 48, height: 48, borderRadius: 14,
            background: `linear-gradient(135deg, ${section.accentColor}30, ${section.accentColor}12)`,
            border: `1px solid ${section.accentColor}40`,
            display: "flex", alignItems: "center", justifyContent: "center",
          }}>
            <section.icon size={22} color={section.accentColor} strokeWidth={1.7} />
          </div>
          <div>
            <h2 style={{ margin: 0, color: C.text, fontFamily: font, fontSize: 18, fontWeight: 800 }}>{section.label}</h2>
            <p style={{ margin: "3px 0 0", color: C.textMuted, fontFamily: font, fontSize: 13 }}>{section.subtitle}</p>
          </div>
        </div>
      </motion.div>
      <FeedContent />
    </div>
  );
}

// ─── Root App ─────────────────────────────────────────────────────────────────
export default function App() {
  const [currentSection, setCurrentSection] = useState(null);
  const [direction, setDirection] = useState(1);
  const [isHost, setIsHost] = useState(true);
  const isDesktop = useIsDesktop();

  useEffect(() => {
    const link = document.createElement("link");
    link.href = "https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap";
    link.rel = "stylesheet";
    document.head.appendChild(link);
  }, []);

  const navigate = (sectionId) => {
    const target = SECTIONS.find(s => s.id === sectionId);
    if (target) { setDirection(1); setCurrentSection(target); }
  };
  const goBack = () => { setDirection(-1); setCurrentSection(null); };

  const navigateTo = (sectionId) => {
    const target = SECTIONS.find(s => s.id === sectionId);
    if (target) { setDirection(1); setCurrentSection(target); }
  };

  // On desktop, no max-width constraint at all
  const maxW = isDesktop ? "none" : 430;

  return (
    <div style={{
      height: "100vh", width: "100vw",
      background: C.bg,
      display: "flex", justifyContent: "center", alignItems: "stretch",
      overflow: "hidden",
    }}>
      <div style={{
        width: "100%", maxWidth: maxW,
        height: "100vh",
        background: C.surface,
        position: "relative",
        overflow: "hidden",
        boxShadow: "0 0 80px rgba(0,0,0,0.7)",
      }}>
        {/* Ambient glow */}
        <div style={{
          position: "absolute", top: -60, left: "50%", transform: "translateX(-50%)",
          width: 300, height: 120, borderRadius: "50%",
          background: `radial-gradient(ellipse, ${C.accentDim}55 0%, transparent 70%)`,
          pointerEvents: "none", zIndex: 0,
        }} />

        {/* Role toggle (dev tool) — only show on mobile or when no desktop sidebar */}
        {!isDesktop && (
          <div style={{
            position: "fixed", top: 12, right: currentSection ? 12 : 60,
            zIndex: 9998,
            background: C.card, border: `1px solid ${C.border}`,
            borderRadius: 20, padding: "4px 4px 4px 10px",
            display: "flex", alignItems: "center", gap: 6,
            boxShadow: "0 2px 12px rgba(0,0,0,0.4)",
          }}>
            <span style={{ fontFamily: font, fontSize: 10, color: C.textMuted, fontWeight: 600, textTransform: "uppercase", letterSpacing: "0.05em" }}>
              {isHost ? "Host" : "Member"}
            </span>
            <button onClick={() => setIsHost(h => !h)} style={{
              width: 34, height: 18, borderRadius: 9, border: "none",
              background: isHost ? C.accent : C.border, cursor: "pointer",
              position: "relative", transition: "background 0.2s",
            }}>
              <motion.div animate={{ x: isHost ? 16 : 2 }} transition={{ type: "spring", stiffness: 400, damping: 28 }}
                style={{ width: 14, height: 14, borderRadius: "50%", background: "#fff", position: "absolute", top: 2 }} />
            </button>
          </div>
        )}

        {/* Navigation */}
        <AnimatePresence mode="sync" custom={direction}>
          {!currentSection ? (
            <motion.div key="home" custom={direction} variants={slideVariants}
              initial="enter" animate="center" exit="exit" transition={springTrans}
              style={{ position: "absolute", inset: 0, zIndex: 1, background: C.surface, overflow: "hidden" }}>
              {isDesktop ? (
                <HomeScreenDesktop onNavigate={navigate} isHost={isHost} setIsHost={setIsHost} />
              ) : (
                <HomeScreenMobile onNavigate={navigate} />
              )}
            </motion.div>
          ) : (
            <motion.div key={currentSection.id} custom={direction} variants={slideVariants}
              initial="enter" animate="center" exit="exit" transition={springTrans}
              style={{ position: "absolute", inset: 0, zIndex: 1, background: C.surface, overflow: "hidden" }}>
              {currentSection.id === "planning" ? (
                <Planning section={currentSection} onBack={goBack} isHost={isHost} onNavigate={navigateTo} />
              ) : currentSection.id === "recaps" ? (
                <Recaps section={currentSection} onBack={goBack} isHost={isHost} onNavigate={navigateTo} />
              ) : (
                <GenericSectionScreen section={currentSection} onBack={goBack} onNavigate={navigateTo} isHost={isHost} />
              )}
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </div>
  );
}
