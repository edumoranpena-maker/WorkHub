              team.
            </span>
          </h1>
          <p style={{ margin: 0, color: C.textMuted, fontFamily: font, fontSize: 14 }}>4 new updates since your last visit</p>

          {/* Stats row */}
          <div style={{ display: "flex", gap: 10, marginTop: 18, flexWrap: "wrap" }}>
            {[
              { icon: TrendingUp, label: "Active",   value: "24", color: C.green       },
              { icon: Clock,      label: "Pending",  value: "7",  color: C.amber       },
              { icon: Bell,       label: "Mentions", value: "3",  color: C.accentLight },
            ].map(stat => (
              <div key={stat.label} style={{
                display: "flex", alignItems: "center", gap: 8,
                background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: "9px 14px",
              }}>
                <stat.icon size={14} color={stat.color} strokeWidth={2} />
                <span style={{ color: C.textMuted, fontFamily: font, fontSize: 12, fontWeight: 500 }}>{stat.label}</span>
                <span style={{ color: stat.color, fontFamily: font, fontSize: 13, fontWeight: 700 }}>{stat.value}</span>
              </div>
            ))}
          </div>
        </div>

        {/* Feed — 1 post per section */}
        <div style={{ padding: "0 28px 48px", maxWidth: 760, display: "flex", flexDirection: "column", gap: 12 }}>
          <p style={{ margin: "0 0 8px", fontFamily: font, fontSize: 11, fontWeight: 700, color: C.textMuted, textTransform: "uppercase", letterSpacing: "0.08em" }}>
            Latest from each section
          </p>
          {SECTIONS.map((s, i) => (
            <motion.div key={s.id} initial={{ opacity: 0, y: 16 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: 0.07 + i * 0.07 }}>
              <HomePreviewCard section={s} onClick={() => onNavigate(s.id)} />
            </motion.div>
          ))}
        </div>
      </div>
    </div>
  );
}

// ─── HomeScreen (Mobile) ──────────────────────────────────────────────────────
function HomeScreenMobile({ onNavigate }) {
