        }}>
          <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
            <Sparkles size={13} color={C.accentLight} />
            <span style={{ color: C.accentLight, fontFamily: font, fontSize: 11, fontWeight: 700, letterSpacing: "0.07em", textTransform: "uppercase" }}>Your workspace</span>
          </div>
